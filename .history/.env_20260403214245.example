# Server Configuration
PORT=8300
HOST=0.0.0.0

# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Your Telegram user ID(s) - comma-separated for multiple admins
# Get your user ID by messaging @userinfobot on Telegram
TELEGRAM_ADMIN_IDS=123456789

# Base URL for stream links (use your public IP or domain)
# For local testing, use localhost; for production, use your server's public address
TELEGRAM_STREAM_BASE_URL=http://localhost:8300
