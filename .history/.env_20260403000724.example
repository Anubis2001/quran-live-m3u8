# Server Configuration
PORT=8300
HOST=0.0.0.0

# Logging Configuration
CONSOLE_LOG_LEVEL=INFO
FILE_LOG_LEVEL=VERBOSE
LOG_FILE_PATH=./logs/app.log

# SSL/HTTPS Configuration (Optional)
# Set ENABLE_HTTPS=true to enable HTTPS support
ENABLE_HTTPS=false

# SSL Certificate Paths (required if ENABLE_HTTPS=true)
# You can generate self-signed certificates using:
# openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365 -nodes
SSL_KEY_PATH=./ssl/key.pem
SSL_CERT_PATH=./ssl/cert.pem

# HTTPS Port (defaults to 8443 if not specified)
HTTPS_PORT=8443

# Force HTTPS (optional - redirects all HTTP requests to HTTPS)
FORCE_HTTPS=false
